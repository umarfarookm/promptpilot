DATABASE_URL=postgresql://promptpilot:promptpilot@localhost:5432/promptpilot
PORT=3001
CORS_ORIGIN=http://localhost:3000

# AI Provider — choose one: ollama (default), openai, anthropic
AI_PROVIDER=ollama

# Required for openai / anthropic providers (not needed for ollama)
# AI_API_KEY=sk-...

# Model override (optional — sensible defaults are used per provider)
# AI_MODEL=llama3.2          # ollama default
# AI_MODEL=gpt-4o-mini       # openai default
# AI_MODEL=claude-sonnet-4-20250514  # anthropic default

# Ollama-specific (only when AI_PROVIDER=ollama)
OLLAMA_URL=http://localhost:11434
